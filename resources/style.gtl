{{define "style"}}
<style>
:root {
    --color-bg: #f8f9fa;
    --color-surface: #ffffff;
    --color-border: #dee2e6;
    --color-text: #212529;
    --color-text-muted: #6c757d;
    --color-primary: #4361ee;
    --color-primary-light: #eef0fd;

    --color-passed-bg: #d1fae5;
    --color-passed-border: #6ee7b7;
    --color-passed-text: #065f46;

    --color-failed-bg: #fee2e2;
    --color-failed-border: #fca5a5;
    --color-failed-text: #7f1d1d;

    --color-skipped-bg: #fef9c3;
    --color-skipped-border: #fde047;
    --color-skipped-text: #713f12;

    --color-code-bg: #f1f5f9;
    --color-code-border: #cbd5e1;

    --header-height: 56px;
    --sidebar-width: 260px;
    --radius: 8px;
    --font-sans: system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    --font-mono: ui-monospace, "SFMono-Regular", Menlo, Monaco, Consolas, "Liberation Mono", monospace;
}

*, *::before, *::after { box-sizing: border-box; }

html, body {
    margin: 0;
    padding: 0;
    background-color: var(--color-bg);
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
}

a {
    color: var(--color-primary);
    text-decoration: none;
}
a:hover { text-decoration: underline; }

h1, h2, h3, h4, h5, h6 {
    margin-top: 0;
    font-weight: 600;
    line-height: 1.3;
}

/* ── Header ── */
.site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    background: var(--color-primary);
    color: #fff;
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
}
.site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 24px;
}
.site-header__title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: .01em;
    text-transform: capitalize;
}
.site-header__home {
    color: rgba(255,255,255,.85);
    font-size: .9rem;
}
.site-header__home:hover { color: #fff; }

/* ── Layout ── */
.layout {
    display: flex;
    min-height: calc(100vh - var(--header-height));
}
.layout--index {
    display: block;
    padding: 32px 24px;
    max-width: 960px;
    margin: 0 auto;
}

/* ── Sidebar ── */
.sidebar {
    width: var(--sidebar-width);
    min-width: var(--sidebar-width);
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
    padding: 24px 0;
    position: sticky;
    top: var(--header-height);
    height: calc(100vh - var(--header-height));
    overflow-y: auto;
}
.sidebar__heading {
    padding: 0 16px 8px;
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--color-text-muted);
}
.sidebar__list {
    list-style: none;
    margin: 0;
    padding: 0;
}
.sidebar__list li a {
    display: block;
    padding: 7px 16px;
    font-size: .875rem;
    color: var(--color-text);
    text-transform: capitalize;
    border-left: 3px solid transparent;
    transition: background .15s, border-color .15s;
}
.sidebar__list li a:hover {
    background: var(--color-bg);
    text-decoration: none;
}
.sidebar__list li.test-passed a { border-left-color: var(--color-passed-border); }
.sidebar__list li.test-failed a {
    border-left-color: var(--color-failed-border);
    color: var(--color-failed-text);
}
.sidebar__list li.test-not-run a {
    border-left-color: var(--color-skipped-border);
    color: var(--color-skipped-text);
}

/* ── Main content ── */
.main-content {
    flex: 1;
    padding: 32px 40px;
    min-width: 0;
}

/* ── Status badge ── */
.badge {
    display: inline-block;
    padding: 2px 10px;
    border-radius: 999px;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    vertical-align: middle;
    margin-left: 8px;
}
.badge--passed {
    background: var(--color-passed-bg);
    color: var(--color-passed-text);
}
.badge--failed {
    background: var(--color-failed-bg);
    color: var(--color-failed-text);
}
.badge--skipped {
    background: var(--color-skipped-bg);
    color: var(--color-skipped-text);
}

/* ── Test method block ── */
.testmethod {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--color-border);
}
.testmethod:last-child { border-bottom: none; }
.testmethod__title {
    font-size: 1.25rem;
    color: var(--color-text);
    text-transform: capitalize;
}
.testmethod__comment {
    color: var(--color-text-muted);
    margin: 4px 0 12px;
}

/* ── Scenario card ── */
.scenario {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 20px 24px;
    margin-top: 12px;
}
.scenario__section-label {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--color-text-muted);
    margin-bottom: 6px;
}

/* ── Code blocks ── */
pre, code {
    font-family: var(--font-mono);
    font-size: .875rem;
}
pre {
    background: var(--color-code-bg);
    border: 1px solid var(--color-code-border);
    border-radius: var(--radius);
    padding: 16px;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
    margin: 0 0 16px;
}
pre.test-passed {
    background: var(--color-passed-bg);
    border-color: var(--color-passed-border);
    color: var(--color-passed-text);
}
pre.test-failed {
    background: var(--color-failed-bg);
    border-color: var(--color-failed-border);
    color: var(--color-failed-text);
}
pre.test-not-run {
    background: var(--color-skipped-bg);
    border-color: var(--color-skipped-border);
    color: var(--color-skipped-text);
}

/* ── Syntax highlighting ── */
.highlight .literal  { color: #0e7490; }
.highlight .keyword  { color: var(--color-primary); font-weight: 600; }
.highlight .constant { color: #7c3aed; }
.highlight .quote    { color: #059669; }
.highlight .interestingGiven { background: #fef9c3; border-radius: 3px; padding: 1px 3px; }

/* ── Interesting givens table ── */
.interestingGivens-table {
    width: 100%;
    border-collapse: collapse;
    font-size: .875rem;
    margin-bottom: 16px;
}
.interestingGivens-table th,
.interestingGivens-table td {
    padding: 8px 12px;
    border: 1px solid var(--color-border);
    text-align: left;
    vertical-align: middle;
}
.interestingGivens-table th {
    background: var(--color-code-bg);
    font-weight: 600;
    width: 35%;
}
.interestingGivens-table td { background: var(--color-surface); }

/* ── Collapsible log sections ── */
.log-section {
    margin-bottom: 12px;
}
.log-section summary {
    cursor: pointer;
    font-size: .875rem;
    font-weight: 600;
    color: var(--color-primary);
    padding: 6px 0;
    user-select: none;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
}
.log-section summary::before {
    content: "▶";
    font-size: .65rem;
    transition: transform .2s;
}
.log-section[open] summary::before { transform: rotate(90deg); }
.log-section summary:hover { text-decoration: underline; }
.log-section .log-body { margin-top: 6px; }

/* ── Index cards ── */
.index-heading {
    font-size: 1.5rem;
    margin-bottom: 24px;
}
.index-cards { display: flex; flex-direction: column; gap: 16px; }
.index-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
}
.index-card.test-passed { border-left: 4px solid var(--color-passed-border); }
.index-card.test-failed { border-left: 4px solid var(--color-failed-border); }
.index-card.test-not-run { border-left: 4px solid var(--color-skipped-border); }
.index-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 20px;
    border-bottom: 1px solid var(--color-border);
}
.index-card__header a {
    font-weight: 600;
    font-size: 1rem;
    text-transform: capitalize;
    color: var(--color-text);
}
.index-card__tests {
    list-style: none;
    margin: 0;
    padding: 8px 0;
}
.index-card__tests li a {
    display: block;
    padding: 5px 20px;
    font-size: .875rem;
    text-transform: capitalize;
    color: var(--color-text);
}
.index-card__tests li.test-failed a { color: var(--color-failed-text); }
.index-card__tests li.test-not-run a { color: var(--color-skipped-text); }
.index-card__tests li a:hover { text-decoration: underline; }
</style>
{{end}}