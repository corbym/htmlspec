{{define "contents"}}
<h1 class="index-heading">Test Report</h1>
<div class="index-cards">
{{range $indexData := .}}
    {{$overallResult := OverallTestResult $indexData.TestData}}
    <div class="index-card {{$overallResult}}">
        <div class="index-card__header">
            <a href="{{$indexData.Ref}}">{{$indexData.Title}}</a>
            {{if eq $overallResult "test-passed"}}
                <span class="badge badge--passed">Passed</span>
            {{else}}
                <span class="badge badge--failed">Failed</span>
            {{end}}
        </div>
        <ul class="index-card__tests">
        {{range $testData := .TestData}}
            {{if $testData.TestResult.Failed}}
                <li class="test-failed"><a href="{{$indexData.Ref}}#{{$testData.TestResult.TestID}}">{{$testData.TestTitle}}</a></li>
            {{else if $testData.TestResult.Skipped}}
                <li class="test-not-run"><a href="{{$indexData.Ref}}#{{$testData.TestResult.TestID}}">{{$testData.TestTitle}}</a></li>
            {{else}}
                <li class="test-passed"><a href="{{$indexData.Ref}}#{{$testData.TestResult.TestID}}">{{$testData.TestTitle}}</a></li>
            {{end}}
        {{end}}
        </ul>
    </div>
{{end}}
</div>
{{end}}