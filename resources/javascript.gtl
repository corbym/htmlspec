{{define "javascript"}}
<script>
(function () {
    "use strict";

    // Highlight tokens inside an element's text content by wrapping matches in <span> tags.
    function highlight(element, pairs) {
        if (!pairs.length) return;
        if (element.dataset.highlighted) return;

        var groups = [];
        var classes = [];
        pairs.forEach(function (p) {
            groups.push("(" + p.pattern + ")");
            classes.push(p.cssClass);
        });
        var regex = new RegExp(groups.join("|"), "g");

        element.innerHTML = element.innerHTML.replace(regex, function () {
            for (var i = 1; i < arguments.length - 2; i++) {
                if (arguments[i]) {
                    return '<span class="' + classes[i - 1] + '">' + arguments[i] + '</span>';
                }
            }
            return arguments[0];
        });
        element.dataset.highlighted = "true";
    }

    document.addEventListener("DOMContentLoaded", function () {
        // Highlight BDD keywords in specification blocks
        document.querySelectorAll(".highlight.specification").forEach(function (el) {
            highlight(el, [
                {pattern: '"[^"]*"',   cssClass: "quote"},
                {pattern: "\\bGiven\\b", cssClass: "keyword"},
                {pattern: "\\bAnd\\b",   cssClass: "keyword"},
                {pattern: "\\bWhen\\b",  cssClass: "keyword"},
                {pattern: "\\bThen\\b",  cssClass: "keyword"},
                {pattern: "[A-Z_]{2,}", cssClass: "constant"},
                {pattern: "[\\d]+",     cssClass: "literal"}
            ]);
        });

        // Highlight keywords in results blocks
        document.querySelectorAll(".highlight.results").forEach(function (el) {
            highlight(el, [
                {pattern: '"[^"]*"',      cssClass: "quote"},
                {pattern: "\\bExpected\\b", cssClass: "keyword"},
                {pattern: "\\bgot\\b",      cssClass: "keyword"},
                {pattern: "[A-Z_]{2,}",   cssClass: "constant"},
                {pattern: "[\\d]+",        cssClass: "literal"}
            ]);
        });

        // Highlight interesting-given values and XML in captured-IO blocks
        document.querySelectorAll(".scenario").forEach(function (scenario) {
            var igPairs = [];
            scenario.querySelectorAll(".interestingGiven").forEach(function (cell) {
                var val = cell.textContent.trim();
                if (val) {
                    igPairs.push(
                        {pattern: '"' + val + '"', cssClass: "interestingGiven"},
                        {pattern: '\\b' + val + '\\b', cssClass: "interestingGiven"}
                    );
                }
            });

            scenario.querySelectorAll(".log-body.highlight.xml").forEach(function (el) {
                if (!el.children.length || el.children[0].tagName.toLowerCase() !== "svg") {
                    highlight(el, igPairs.concat([
                        {pattern: '"[^"]*"',         cssClass: "quote"},
                        {pattern: "&lt;[^\\s&]+",    cssClass: "keyword"},
                        {pattern: "\\??&gt;",        cssClass: "keyword"},
                        {pattern: "\\s[\\w:-]+=",    cssClass: "constant"}
                    ]));
                }
            });
        });
    });
}());
</script>
{{end}}