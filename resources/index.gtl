{{define "index"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Test Report Index</title>
{{template "style" .}}
</head>
<body>
    <header class="site-header">
        <div class="site-header__inner">
            <span class="site-header__title">Test Report</span>
        </div>
    </header>
    <div class="layout layout--index">
        <main class="main-content">
{{template "contents" .}}
        </main>
    </div>
{{template "javascript" .}}
</body>
</html>
{{end}}