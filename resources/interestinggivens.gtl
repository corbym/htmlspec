{{define "interesting-givens"}}
{{if .}}
<details class="log-section" open>
    <summary>Interesting Givens</summary>
    <div class="log-body">
        <table class="interestingGivens-table">
            {{range $key, $value := .}}
            <tr>
                <th class="key">{{$key}}</th>
                <td class="interestingGiven">{{$value}}</td>
            </tr>
            {{end}}
        </table>
    </div>
</details>
{{end}}
{{end}}