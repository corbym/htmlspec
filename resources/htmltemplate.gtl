{{define "base"}}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{.Title}}</title>
{{template "style" .}}
</head>
<body>
    <header class="site-header">
        <div class="site-header__inner">
            <span class="site-header__title">{{.Title}}</span>
            <a class="site-header__home" href="index.html">&#8962; Index</a>
        </div>
    </header>
    <div class="layout">
        <nav class="sidebar">
{{template "contents" .}}
        </nav>
        <main class="main-content">
{{template "test-body" .}}
        </main>
    </div>
{{template "javascript" .}}
</body>
</html>
{{end}}